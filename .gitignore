# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Environment files
.env
.env.local
.env.*.local

# Kubernetes config
kubeconfig
*.kubeconfig

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
.tmp/
*.tmp
*.log

# Helm
charts/
*.tgz

# Backup files
*.backup
*.bak

# Certificate files (should be managed by cert-manager)
*.crt
*.key
*.pem
*.p12
*.pfx

# GCP credentials
*-key.json
service-account*.json
/.bob/
/.plans/
/.gemini/
/conductor/
/.gemini/
